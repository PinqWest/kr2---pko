<Window x:Class="KR2.JournalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Полный журнал TimeEntry"
        Height="560"
        Width="980"
        MinHeight="460"
        MinWidth="860"
        Background="#F5F7FB">
    <Window.Resources>
        <Style x:Key="HeaderCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#111827" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#EEF4FF" />
            <Setter Property="Foreground" Value="#1D4ED8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="BorderBrush" Value="#DBEAFE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource HeaderCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Foreground="White"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Text="Полный журнал TimeEntry" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#9CA3AF"
                               FontSize="12"
                               Text="История всех записей времени с фильтрацией" />
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Margin="0,0,12,0"
                               VerticalAlignment="Center"
                               Foreground="#93C5FD"
                               Text="{Binding StatusMessage}" />
                    <CheckBox Margin="0,0,12,0"
                              VerticalAlignment="Center"
                              Foreground="#E5E7EB"
                              FontWeight="SemiBold"
                              Content="Только сегодня"
                              IsChecked="{Binding IsTodayOnly}" />
                    <Button Style="{StaticResource GhostButtonStyle}"
                            Margin="0,0,8,0"
                            Content="Сохранить"
                            Command="{Binding SaveChangesCommand}" />
                    <Button Style="{StaticResource GhostButtonStyle}"
                            Margin="0,0,8,0"
                            Content="Архивировать"
                            Command="{Binding ArchiveCommand}" />
                    <Button Style="{StaticResource GhostButtonStyle}"
                            Content="Обновить"
                            Command="{Binding RefreshCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="10"
                BorderBrush="#E9EDF5"
                BorderThickness="1">
            <DataGrid ItemsSource="{Binding Entries}"
                      SelectedItem="{Binding SelectedEntry}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      AlternatingRowBackground="#F8FAFC"
                      RowHeaderWidth="0"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Width="3*" Header="Задача" Binding="{Binding TaskTitle}" />
                    <DataGridTextColumn Width="2*" Header="Старт" Binding="{Binding StartAtLocal, StringFormat={}{0:dd.MM.yyyy HH:mm}}" />
                    <DataGridTextColumn Width="2*" Header="Конец" Binding="{Binding EndAtLocal, StringFormat={}{0:dd.MM.yyyy HH:mm}}" />
                    <DataGridTextColumn Width="2*" Header="Комментарий" Binding="{Binding Comment}" />
                    <DataGridTextColumn Width="*" IsReadOnly="True" Header="Длительность" Binding="{Binding Duration}" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>
