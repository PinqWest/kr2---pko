<Window x:Class="KR2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Time Tracker"
        Height="620"
        Width="980"
        MinHeight="560"
        MinWidth="900"
        Background="#F5F7FB">
    <Window.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="BorderBrush" Value="#E9EDF5" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="BorderBrush" Value="#2563EB" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#111827" />
            <Setter Property="BorderBrush" Value="#111827" />
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#EEF4FF" />
            <Setter Property="Foreground" Value="#1D4ED8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="BorderBrush" Value="#DBEAFE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="4"
                                    BorderThickness="1.5"
                                    BorderBrush="#9CA3AF"
                                    Background="White"
                                    Margin="0,0,8,0">
                                <Path x:Name="Tick"
                                      Data="M 3 9 L 7 13 L 15 4"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#2563EB" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="#2563EB" />
                                <Setter TargetName="Tick" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#111827"
                CornerRadius="16"
                Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Foreground="White" FontSize="24" FontWeight="Bold" Text="Time Tracker" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#D1D5DB"
                               FontSize="13"
                               Text="Профессиональный старт: WPF + EF Core + SQLite" />
                </StackPanel>
                <Border Grid.Column="1"
                        Background="#1F2937"
                        CornerRadius="10"
                        Padding="14,8"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10"
                                 Height="10"
                                 Margin="0,0,8,0"
                                 VerticalAlignment="Center"
                                 Fill="{Binding StatusBrush}" />
                        <TextBlock Foreground="{Binding StatusBrush}"
                                   FontWeight="SemiBold"
                                   Text="{Binding StatusMessage}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="Учет рабочего времени" />
                        <TextBlock Margin="0,6,0,0" Foreground="#6B7280" Text="{Binding ActiveTaskText}" />
                        <TextBlock Margin="0,14,0,6"
                                   Foreground="#374151"
                                   FontWeight="SemiBold"
                                   Text="Выбери задачу" />
                        <ComboBox Height="38"
                                  ItemsSource="{Binding Tasks}"
                                  SelectedItem="{Binding SelectedTask}"
                                  DisplayMemberPath="DisplayName" />

                        <TextBlock Margin="0,12,0,6"
                                   Foreground="#374151"
                                   FontWeight="SemiBold"
                                   Text="Комментарий к сессии" />
                        <TextBox Height="38"
                                 Padding="10,8"
                                 BorderBrush="#D1D5DB"
                                 BorderThickness="1"
                                 Background="White"
                                 Text="{Binding SessionCommentInput, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Margin="0,12,0,6"
                                   Foreground="#374151"
                                   FontWeight="SemiBold"
                                   Text="Новая задача" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="170" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Height="38"
                                     Padding="10,8"
                                     BorderBrush="#D1D5DB"
                                     BorderThickness="1"
                                     Background="White"
                                     Text="{Binding TaskTitleInput, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2"
                                    Height="38"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Content="Создать задачу"
                                    Command="{Binding CreateTaskCommand}" />
                        </Grid>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Height="44"
                                    Content="Start"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding StartTimerCommand}" />
                            <Button Grid.Column="2"
                                    Height="44"
                                    Content="Pause"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Command="{Binding PauseTimerCommand}" />
                            <Button Grid.Column="4"
                                    Height="44"
                                    Content="Resume"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Command="{Binding ResumeTimerCommand}" />
                            <Button Grid.Column="6"
                                    Height="44"
                                    Content="Stop"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding StopTimerCommand}" />
                        </Grid>

                        <Border Margin="0,14,0,0"
                                Padding="10"
                                Background="#F8FAFC"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="10">
                            <DockPanel LastChildFill="False">
                                <CheckBox DockPanel.Dock="Left"
                                          Style="{StaticResource FilterCheckBoxStyle}"
                                          Content="Только сегодня"
                                          IsChecked="{Binding IsTodayOnly}" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <Button Style="{StaticResource GhostButtonStyle}"
                                            Margin="0,0,8,0"
                                            Content="Отчеты и экспорт"
                                            Command="{Binding OpenReportsCommand}" />
                                    <Button Style="{StaticResource GhostButtonStyle}"
                                            Content="Открыть полный журнал"
                                            Command="{Binding OpenJournalCommand}" />
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="Последние TimeEntry" />
                        <TextBlock Margin="0,6,0,10" Foreground="#6B7280" Text="Последние 8 записей времени" />

                        <ScrollViewer MaxHeight="260"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding RecentEntries}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="10"
                                                Background="#F9FAFB"
                                                BorderBrush="#EEF2F7"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="90" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           FontWeight="SemiBold"
                                                           Foreground="#111827"
                                                           Text="{Binding TaskTitle}" />
                                                <TextBlock Grid.Column="1"
                                                           HorizontalAlignment="Right"
                                                           Foreground="#6B7280"
                                                           Text="{Binding StartedAt}" />
                                                <TextBlock Grid.Column="2"
                                                           HorizontalAlignment="Right"
                                                           Foreground="#6B7280"
                                                           Text="{Binding EndedAt}" />
                                                <TextBlock Grid.Column="3"
                                                           HorizontalAlignment="Right"
                                                           Foreground="#1D4ED8"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding Duration}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Foreground="#6B7280" FontSize="12" Text="СЕГОДНЯ" />
                        <TextBlock Margin="0,8,0,0" FontSize="28" FontWeight="Bold" Text="{Binding TodaySummary}" />
                        <TextBlock Margin="0,6,0,0" Foreground="#9CA3AF" Text="Суммарное время за день" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Foreground="#6B7280" FontSize="12" Text="СТАТУС" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Ellipse Width="10"
                                     Height="10"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center"
                                     Fill="{Binding StatusBrush}" />
                            <TextBlock FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding StatusBrush}"
                                       Text="{Binding StatusMessage}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
