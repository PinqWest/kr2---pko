<Window x:Class="KR2.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Отчеты и экспорт"
        Height="700"
        Width="1080"
        MinHeight="620"
        MinWidth="980"
        Background="#F5F7FB">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="#111827" CornerRadius="12" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock FontSize="22" FontWeight="SemiBold" Foreground="White" Text="Отчеты и экспорт" />
                    <TextBlock Margin="0,4,0,0" Foreground="#9CA3AF" Text="{Binding StatusMessage}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Height="34" Margin="0,0,8,0" Padding="10,6" Content="Сформировать" Command="{Binding BuildReportCommand}" />
                    <Button Height="34" Margin="0,0,8,0" Padding="10,6" Content="Экспорт CSV" Command="{Binding ExportCsvCommand}" />
                    <Button Height="34" Padding="10,6" Content="Экспорт PDF" Command="{Binding ExportPdfCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Background="White" BorderBrush="#E9EDF5" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Период" />
                        <TextBlock Margin="0,10,0,4" Foreground="#6B7280" Text="Дата начала" />
                        <DatePicker SelectedDate="{Binding StartDate}" />
                        <TextBlock Margin="0,10,0,4" Foreground="#6B7280" Text="Дата окончания" />
                        <DatePicker SelectedDate="{Binding EndDate}" />
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#E9EDF5" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="План-факт" />
                        <TextBlock Margin="0,10,0,4" Foreground="#6B7280" Text="Цель часов в день" />
                        <TextBox Text="{Binding DayGoalHours}" />
                        <TextBlock Margin="0,10,0,4" Foreground="#6B7280" Text="Цель часов в неделю" />
                        <TextBox Text="{Binding WeekGoalHours}" />
                        <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="{Binding TotalHours, StringFormat=Итого: {0}}" />
                        <TextBlock Margin="0,4,0,0" Text="{Binding PlanFactDay, StringFormat=Выполнение по дням: {0}}" />
                        <TextBlock Margin="0,2,0,0" Text="{Binding PlanFactWeek, StringFormat=Выполнение по неделям: {0}}" />
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#E9EDF5" BorderThickness="1" CornerRadius="10" Padding="14">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="По проектам" />
                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding ByProjects}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,6">
                                        <TextBlock DockPanel.Dock="Right" FontWeight="SemiBold" Text="{Binding Hours}" />
                                        <TextBlock Text="{Binding Name}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="240" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="White" BorderBrush="#E9EDF5" BorderThickness="1" CornerRadius="10" Padding="12">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Text="Диаграмма: часы по дням" />
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding ByDays}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="55" Margin="4,0,4,0" VerticalAlignment="Bottom">
                                            <Border Height="{Binding ColumnHeight}" Background="#3B82F6" CornerRadius="4,4,0,0" VerticalAlignment="Bottom" />
                                            <TextBlock Margin="0,4,0,0" HorizontalAlignment="Center" FontSize="11" Text="{Binding DayLabel}" />
                                            <TextBlock HorizontalAlignment="Center" FontSize="11" Foreground="#6B7280" Text="{Binding HoursLabel}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="White" BorderBrush="#E9EDF5" BorderThickness="1" CornerRadius="10" Padding="12">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="По задачам" />
                            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding ByTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock DockPanel.Dock="Right" FontWeight="SemiBold" Text="{Binding Hours}" />
                                            <TextBlock Text="{Binding Name}" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="White" BorderBrush="#E9EDF5" BorderThickness="1" CornerRadius="10" Padding="12">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="По тегам" />
                            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding ByTags}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <DockPanel Margin="0,0,0,6">
                                            <TextBlock DockPanel.Dock="Right" FontWeight="SemiBold" Text="{Binding Hours}" />
                                            <TextBlock Text="{Binding Name}" />
                                        </DockPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
